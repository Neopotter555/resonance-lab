{
  "name": "resonance-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "api:build": "tsc -p apps/api/tsconfig.json",
    "api:dev": "tsx apps/api/src/main.ts",
    "api:start": "node apps/api/dist/main.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "validate": "npm run lint && npm run build && npm run api:build",
    "smoke:visual": "node scripts/smoke-visual.mjs",
    "deploy:netlify": "npx netlify-cli deploy --build",
    "deploy:vercel": "npx vercel deploy",
    "deploy:preview": "npm run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "three": "^0.185.0",
    "tone": "^15.1.22",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.12",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
